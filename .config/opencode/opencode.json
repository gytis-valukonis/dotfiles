{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openai"
  ],
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "serena",
        "start-mcp-server",
        "--context=ide"
      ],
      "enabled": true,
      "timeout": 15000
    }
  },
  "plugin": [
    "./plugins/caveman/plugin.js"
  ]
}
